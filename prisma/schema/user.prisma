model User {
  id       String     @id @default(uuid())
  name     String     @db.VarChar(255)
  email    String     @unique @db.VarChar(300)
  password String
  role     Role
  status   UserStatus @default(ACTIVE)
  phone    String?

  gearItems    GearItem[]
  rentalOrders RentalOrder[]
  reviews      Review[]
  payments     Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
