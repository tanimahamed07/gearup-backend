model User {
  id           String        @id @default(uuid())
  name         String        @db.VarChar(255)
  email        String        @unique @db.VarChar(300)
  password     String
  role         Role
  status       UserStatus    @default(ACTIVE)
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  payments     Payment[]
  reviews      Review[]
  gearItems    GearItem[]
  rentalOrders RentalOrder[]

  @@map("users")
}
